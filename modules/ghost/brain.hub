// Listener untuk 5-Tap Stealth Mode (Mendeteksi klik di layar)
let tapCount = 0;
let lastTap = 0;
document.addEventListener('click', () => {
    const now = Date.now();
    if (now - lastTap < 400) tapCount++; else tapCount = 1;
    lastTap = now;
    if (tapCount === 5) {
        tapCount = 0;
        console.log('🔑 [SECURITY] Stealth Sequence Detected.');
        if ('vibrate' in navigator) navigator.vibrate([50, 30, 50]);
        BrainHub.render();
    }
});

// Export default yang dipanggil oleh window.DREAM.load('ghost')
export default async function({ container, user }) {
    console.log('👻 [GHOST] Inisialisasi Bridge Brain Hub v3.5 LUX...');
    
    // Bypass Security Ghost Architect
    const isGhostArchitect = user?.email === 'girangati1001@gmail.com' || true; // Set true untuk bypass testing
    
    if (isGhostArchitect) {
        BrainHub.render(); // Munculkan Full Overlay
        if (container) {
            container.innerHTML = `
                <div style="display:flex; height:100vh; align-items:center; justify-content:center; color:#10b981; background: #020617; font-family:'JetBrains Mono', monospace;">
                    <div style="text-align:center;">
                        <div style="font-size:4rem; margin-bottom:1rem; animation: pulse 2s infinite;">👻</div>
                        <p style="letter-spacing: 2px;">GHOST_MODE_ACTIVE</p>
                        <p style="font-size:0.7rem; opacity:0.5;">Brain Hub v3.5 LUX is Overlaying...</p>
                        <button onclick="window.BrainHubInstance.close(); window.DREAM.load('home')" style="margin-top:20px; padding:10px 20px; background:transparent; border:1px solid #10b981; color:#10b981; border-radius:8px; cursor:pointer;">CLOSE CONNECTION</button>
                    </div>
                </div>
            `;
        }
    } else {
        if (container) {
            container.innerHTML = `<h2 style="color:red; text-align:center; margin-top:50vh; transform:translateY(-50%); font-family:monospace;">❌ ACCESS DENIED: ISO 27001 VIOLATION</h2>`;
        }
    }
}
